    "download-releases": "node dist/download-releases.js",
    "build-schemas": "node dist/build-schemas.js"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@pnpm/find-workspace-dir": "^1000.1.5",
    "dotenv": "^17.4.2",
    "lib": "workspace:*"
  },
  "tsup": {
    "noExternal": [
      "lib"
    ]
  }
}
