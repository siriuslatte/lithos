{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "compile": {
      "dependsOn": [
        "^compile"
      ],
      "outputs": [
        "./dist/**"
      ]
    },
    "build": {
      "dependsOn": [
        "^build",
        "^compile"
      ],
      "outputs": [
        ".next/**",
        "out/**",
        "./dist/**"
      ]
    }
  }
}